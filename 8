def encrypt(text, shift):
    result = ""

    for ch in text:
        if ch.isalpha():
            start = ord('A') if ch.isupper() else ord('a')

            new_char = chr(
                (ord(ch) - start + shift) % 26 + start
            )

            result += new_char
        else:
            result += ch

    return result

message = input("메시지 입력: ")

encrypted = encrypt(message, 3)

print("암호화 결과:", encrypted)
